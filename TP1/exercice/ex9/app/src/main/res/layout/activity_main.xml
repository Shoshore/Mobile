<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Titre -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_agenda"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"
        android:paddingBottom="16dp"/>

    <!-- Date sélectionnée -->
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_date"
        android:textSize="18sp"
        android:paddingBottom="8dp"/>

    <!-- Champ pour ajouter un événement -->
    <EditText
        android:id="@+id/etEvenement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_evenement"
        android:inputType="text"/>

    <!-- Bouton ajouter -->
    <Button
        android:id="@+id/btnAjouter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_ajouter"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"/>

    <!-- Liste des événements -->
    <TextView
        android:id="@+id/tvEvenements"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_evenements"
        android:textStyle="bold"
        android:layout_marginTop="16dp"/>

    <ListView
        android:id="@+id/listEvenements"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="1dp"/>

</LinearLayout>
