<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📸 Publier une photo"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:paddingBottom="16dp"/>

        <!-- Preview image -->
        <ImageView
            android:id="@+id/iv_preview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Placeholder si pas d'image -->
        <LinearLayout
            android:id="@+id/layout_placeholder"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:gravity="center"
            android:background="#EEEEEE"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖼️"
                android:textSize="36sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aucune photo selectionnee"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Boutons photo -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_pick_gallery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🖼️ Galerie"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btn_take_photo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📷 Camera"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Infos photo -->
        <EditText
            android:id="@+id/et_photo_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Titre de la photo"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/et_photo_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="📍 Lieu (ex: Paris, France)"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/et_photo_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Description (optionnelle)"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btn_publish_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Publier"
            android:backgroundTint="#1A1A2E"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_publish_retour"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retour"
            android:backgroundTint="#888888"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>