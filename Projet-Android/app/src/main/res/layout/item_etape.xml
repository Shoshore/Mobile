<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Header : numéro + titre + horaire -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tv_etape_numero"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:background="#1A1A2E"
                android:layout_marginEnd="10dp"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tv_etape_titre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"/>

                <TextView
                    android:id="@+id/tv_etape_horaire"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- Bouton carte étape -->
            <Button
                android:id="@+id/btn_etape_carte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🗺️"
                android:textSize="16sp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_gravity="center_vertical"/>
        </LinearLayout>

        <!-- Détails dépliables -->
        <LinearLayout
            android:id="@+id/layout_etape_details"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible">

            <TextView
                android:id="@+id/tv_etape_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#555555"
                android:paddingTop="6dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tv_etape_duree"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="#2196F3"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_etape_distance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="#4CAF50"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Galerie photos -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📸 Photos du lieu"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:paddingBottom="6dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_etape_photos"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:orientation="horizontal"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>