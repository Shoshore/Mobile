<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tv_result_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Parcours generés"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:padding="16dp"
        android:background="#FFFFFF"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_parcours"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

    <Button
        android:id="@+id/btn_retour"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modifier les criteres"
        android:backgroundTint="#555555"
        android:textColor="#FFFFFF"
        android:layout_margin="12dp"/>

    <Button
        android:id="@+id/btn_meteo_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🌤️ Meteo de cette ville"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:layout_margin="12dp"/>

    <Button
        android:id="@+id/btn_voir_photos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📸 Voir les photos de cette ville"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:layout_margin="12dp"/>

    <Button
        android:id="@+id/btn_voir_carte"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗺️ Voir le parcours sur la carte"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:layout_margin="12dp"/>

</LinearLayout>