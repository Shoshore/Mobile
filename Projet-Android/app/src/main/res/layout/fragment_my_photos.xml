<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_my_photos_titre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingBottom="4dp"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_my_photos_stats"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="12sp"
                android:textColor="#CCCCCC"
                android:layout_gravity="center_vertical"/>

            <Button
                android:id="@+id/btn_my_photos_publier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➕ Publier"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Message vide -->
    <TextView
        android:id="@+id/tv_my_photos_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vous n'avez pas encore publie de photos.\nAppuyez sur + Publier pour commencer !"
        android:textColor="#888888"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- Grille photos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_my_photos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="6dp"/>

    <Button
        android:id="@+id/btn_my_photos_retour"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:backgroundTint="#888888"
        android:textColor="#FFFFFF"
        android:layout_margin="12dp"/>

</LinearLayout>