<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_detail_parcours_titre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tv_detail_parcours_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#CCCCCC"/>

        <!-- Boutons actions -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btn_parcours_detail_carte"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🗺️ Carte"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btn_parcours_detail_meteo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🌤️ Meteo"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Liste des étapes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_etapes_detail"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

    <!-- Bouton retour -->
    <Button
        android:id="@+id/btn_parcours_detail_retour"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Retour"
        android:backgroundTint="#888888"
        android:textColor="#FFFFFF"
        android:layout_margin="12dp"/>

</LinearLayout>