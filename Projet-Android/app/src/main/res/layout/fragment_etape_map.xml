<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header infos étape -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_etape_map_titre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingBottom="2dp"/>

        <TextView
            android:id="@+id/tv_etape_map_horaire"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tv_etape_map_desc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#AAAAAA"/>
    </LinearLayout>

    <!-- Carte -->
    <fragment
        android:id="@+id/map_etape"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Boutons -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp">

        <Button
            android:id="@+id/btn_etape_itineraire"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🧭 Itineraire"
            android:backgroundTint="#4285F4"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btn_etape_map_retour"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Retour"
            android:backgroundTint="#888888"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>