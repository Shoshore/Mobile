<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔔 Notifications"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:paddingBottom="16dp"/>

        <!-- Section : Types de notifications -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Types de notifications"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:paddingBottom="8dp"/>

        <!-- Switch nouvelles photos -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📸 Nouvelles photos"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifie quand un auteur suivi publie"
                        android:textSize="12sp"
                        android:textColor="#888888"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_notif_photos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Switch groupes -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥 Activite des groupes"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifie quand un groupe publie"
                        android:textSize="12sp"
                        android:textColor="#888888"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_notif_groupes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Switch lieux -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Photos par lieu"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="#1A1A2E"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Notifie quand un lieu suivi est actif"
                        android:textSize="12sp"
                        android:textColor="#888888"/>
                </LinearLayout>

                <Switch
                    android:id="@+id/switch_notif_lieux"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section : Sujets suivis -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sujets a suivre"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:paddingBottom="8dp"/>

        <EditText
            android:id="@+id/et_notif_auteur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="📷 Auteur a suivre (ex: Marie L.)"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_notif_lieu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="📍 Lieu a suivre (ex: Paris)"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/et_notif_groupe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="👥 Groupe a suivre"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="20dp"/>

        <!-- Boutons -->
        <Button
            android:id="@+id/btn_save_notifs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾 Sauvegarder les preferences"
            android:backgroundTint="#1A1A2E"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_test_notif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔔 Tester les notifications"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_notif_retour"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retour"
            android:backgroundTint="#888888"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>